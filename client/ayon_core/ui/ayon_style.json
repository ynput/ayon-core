{
    "description": "AYON style data",
    "version": "1.0.0-a.1",
    "global": {
        "font-family": "Nunito Sans",
        "font-size": 10.5,
        "font-size-darwin": 12,
        "font-weight": 400
    },
    "widgets": {
        "QPushButton": {
            "states": [
                "hover",
                "pressed",
                "disabled",
                "checked"
            ],
            "default-variant": "surface",
            "variants": {
                "surface": {
                    "border-radius": 4,
                    "text-padding": [
                        6,
                        6
                    ],
                    "icon-padding": [
                        6,
                        6
                    ],
                    "focus-outline-width": 2,
                    "background-color": "--md-sys-color-surface-container-highest-dark",
                    "color": "--md-sys-color-on-surface-dark",
                    "border-color": "--md-sys-color-on-surface-dark",
                    "focus-outline-color": "--md-sys-color-primary-dark",
                    "hover": {
                        "background-color": "--md-ref-palette-neutral-variant35"
                    },
                    "pressed": {
                        "background-color": "--md-ref-palette-neutral40"
                    },
                    "disabled": {
                        "background-color": "--md-sys-color-surface-container-highest-dark",
                        "opacity": 0.5
                    },
                    "checked": {
                        "background-color": "--md-sys-color-primary-container-dark"
                    }
                },
                "filled": {
                    "background-color": "--md-sys-color-primary-dark",
                    "color": "--md-sys-color-on-primary-dark",
                    "border-color": "--md-sys-color-on-primary-dark",
                    "focus-outline-color": "--md-sys-color-primary-dark",
                    "hover": {
                        "background-color": "#83c1f1"
                    },
                    "pressed": {
                        "background-color": "#80bcea"
                    },
                    "disabled": {
                        "background-color": "--md-sys-color-primary-dark",
                        "opacity": 0.5
                    },
                    "checked": {
                        "background-color": "--md-sys-color-primary-container-dark"
                    }
                },
                "nav": {
                    "background-color": "transparent",
                    "color": "--md-sys-color-on-surface-dark",
                    "border-color": "--md-sys-color-shadow-dark",
                    "focus-outline-color": "--md-sys-color-primary-dark",
                    "hover": {
                        "background-color": "--md-sys-color-background-dark"
                    },
                    "pressed": {
                        "background-color": "--md-ref-palette-secondary20"
                    },
                    "disabled": {
                        "background-color": "transparent",
                        "opacity": 0.5
                    },
                    "checked": {
                        "background-color": "--md-sys-color-primary-container-dark"
                    }
                },
                "nav-small": {
                    "background-color": "transparent",
                    "color": "--md-sys-color-on-surface-dark",
                    "border-color": "--md-sys-color-shadow-dark",
                    "focus-outline-color": "--md-sys-color-primary-dark",
                    "icon-padding": [
                        2,
                        2
                    ],
                    "hover": {
                        "background-color": "--md-sys-color-background-dark"
                    },
                    "pressed": {
                        "background-color": "--md-ref-palette-secondary20"
                    },
                    "disabled": {
                        "background-color": "transparent",
                        "opacity": 0.5
                    },
                    "checked": {
                        "background-color": "--md-sys-color-primary-container-dark"
                    }
                },
                "danger": {
                    "background-color": "--md-sys-color-error-container-dark",
                    "color": "--md-sys-color-on-error-container-dark",
                    "border-color": "--md-sys-color-on-error-container-dark",
                    "focus-outline-color": "--md-sys-color-primary-dark",
                    "hover": {
                        "background-color": "--md-ref-palette-error25"
                    },
                    "pressed": {
                        "background-color": "--md-ref-palette-error35"
                    },
                    "disabled": {
                        "background-color": "--md-sys-color-error-container-dark",
                        "opacity": 0.5
                    },
                    "checked": {
                        "background-color": "--md-sys-color-primary-container-dark"
                    }
                },
                "tertiary": {
                    "background-color": "--md-sys-color-tertiary-dark",
                    "color": "--md-sys-color-on-tertiary-dark",
                    "border-color": "--md-sys-color-on-tertiary-dark",
                    "focus-outline-color": "--md-sys-color-primary-dark",
                    "hover": {
                        "background-color": "--md-ref-palette-tertiary70"
                    },
                    "pressed": {
                        "background-color": "--md-ref-palette-tertiary60"
                    },
                    "disabled": {
                        "background-color": "--md-sys-color-primary-dark",
                        "opacity": 0.5
                    },
                    "checked": {
                        "background-color": "--md-sys-color-primary-container-dark"
                    }
                },
                "text": {
                    "background-color": "transparent",
                    "color": "--md-sys-color-on-surface-dark",
                    "border-color": "--md-sys-color-on-surface-dark",
                    "focus-outline-color": "--md-sys-color-primary-dark",
                    "hover": {
                        "background-color": "--md-ref-palette-neutral20"
                    },
                    "pressed": {
                        "background-color": "--md-ref-palette-neutral25"
                    },
                    "disabled": {
                        "background-color": "transparent",
                        "opacity": 0.5
                    }
                },
                "checked": {
                    "background-color": "--md-sys-color-primary-container-dark"
                },
                "tonal": {
                    "background-color": "--md-sys-color-secondary-container-dark",
                    "color": "--md-sys-color-on-secondary-container-dark",
                    "border-color": "--md-sys-color-on-secondary-container-dark",
                    "focus-outline-color": "--md-sys-color-primary-dark",
                    "hover": {
                        "background-color": "--md-ref-palette-secondary35"
                    },
                    "pressed": {
                        "background-color": "--md-ref-palette-secondary40"
                    },
                    "disabled": {
                        "background-color": "--md-sys-color-secondary-container-dark",
                        "opacity": 0.5
                    },
                    "checked": {
                        "background-color": "--md-sys-color-primary-container-dark"
                    }
                },
                "thumbnail": {
                    "ignore-text": true,
                    "icon-as-background": true,
                    "clip-icon-to-radius": true,
                    "background-color": "--md-sys-color-surface-container-dark",
                    "border-color": "--md-sys-color-surface-container-highest-dark",
                    "border-width": 2
                },
                "entity-card": {
                    "ignore-text": true,
                    "icon-as-background": true,
                    "clip-icon-to-radius": true,
                    "background-color": "--md-sys-color-surface-container-dark",
                    "border-color": "--md-sys-color-surface-container-highest-dark",
                    "border-width": 0,
                    "border-radius": 10
                },
                "tag": {
                    "contrast-text": true,
                    "color": "--md-ref-palette-neutral10",
                    "background-color": "transparent",
                    "border-radius": 8,
                    "border-width": 0,
                    "text-padding": [
                        0,
                        0
                    ],
                    "icon-padding": [
                        0,
                        0
                    ],
                    "hover": {
                        "color": "--md-ref-palette-neutral90",
                        "background-color": "--md-ref-palette-neutral0"
                    }
                },
                "tag-menu": {
                    "text-padding": [
                        8,
                        8
                    ],
                    "color": "@tag_color",
                    "background-color": "transparent",
                    "border-radius": 0,
                    "border-width": 0,
                    "hover": {
                        "background-color": "--md-sys-color-background-dark"
                    },
                    "checked": {
                        "background-color": "--md-sys-color-primary-container-dark"
                    },
                    "disabled": {
                        "background-color": "transparent",
                        "opacity": 0.5
                    }
                },
                "table-filter": {
                    "background-color": "transparent",
                    "color": "--md-sys-color-on-surface-dark",
                    "text-padding": [
                        2,
                        2
                    ],
                    "hover": {
                        "background-color": "transparent"
                    },
                    "pressed": {
                        "background-color": "--md-ref-palette-neutral20"
                    }
                },
                "optional-action": {
                    "background-color": "--md-sys-color-surface-container-lowest-dark",
                    "color": "--md-sys-color-on-surface-dark",
                    "border-radius": 0,
                    "hover": {
                        "background-color": "--md-sys-color-surface-container-dark"
                    },
                    "disabled": {
                        "background-color": "--md-sys-color-surface-container-lowest-dark",
                        "opacity": 0.5
                    }
                }
            }
        },
        "QCheckBox": {
            "states": [
                "checked"
            ],
            "default-variant": "default",
            "variants": {
                "default": {
                    "color": "--md-sys-color-on-surface-dark",
                    "focus-outline-width": 0,
                    "indicator-color": "--md-sys-color-on-surface-dark",
                    "indicator-background-color": "--md-sys-color-surface-container-highest-dark",
                    "indicator-width": 32,
                    "indicator-height": 18,
                    "checkbox-label-spacing": 8,
                    "checked": {
                        "indicator-color": "--md-sys-color-on-primary-dark",
                        "indicator-background-color": "--md-sys-color-primary-dark"
                    }
                },
                "secondary": {
                    "checked": {
                        "indicator-color": "--md-sys-color-on-secondary-dark",
                        "indicator-background-color": "--md-sys-color-secondary-dark"
                    }
                },
                "tertiary": {
                    "checked": {
                        "indicator-color": "--md-sys-color-on-tertiary-dark",
                        "indicator-background-color": "--md-sys-color-tertiary-dark"
                    }
                },
                "button": {
                    "indicator-position": "right",
                    "padding": [
                        6,
                        6
                    ],
                    "color": "--md-sys-color-on-surface-dark",
                    "background-color": "--md-sys-color-surface-container-highest-dark",
                    "indicator-border-width": 1,
                    "indicator-border-color": "--md-sys-color-outline-dark",
                    "border-radius": 6,
                    "checked": {
                        "color": "--md-sys-color-primary-dark",
                        "background-color": "--md-sys-color-primary-container-dark",
                        "indicator-border-color": "--md-sys-color-primary-dark",
                        "indicator-color": "--md-sys-color-on-primary-dark",
                        "indicator-background-color": "--md-sys-color-primary-dark"
                    }
                },
                "menu": {
                    "indicator-position": "right",
                    "indicator-width": 0,
                    "indicator-height": 0
                }
            }
        },
        "QTextEdit": {
            "default-variant": "default",
            "variants": {
                "default": {
                    "background-color": "--md-sys-color-surface-container-dark",
                    "color": "--md-sys-color-on-surface-dark",
                    "link-color": "text-color-link",
                    "border-color": "--md-sys-color-surface-container-dark",
                    "border-width": 1,
                    "border-radius": 4,
                    "padding": [
                        8,
                        12
                    ]
                },
                "low": {
                    "background-color": "--md-sys-color-surface-container-low-dark"
                },
                "high": {
                    "background-color": "--md-sys-color-surface-container-dark"
                },
                "debug-r": {
                    "background-color": "#664444"
                },
                "debug-g": {
                    "background-color": "#446644"
                },
                "debug-b": {
                    "background-color": "#444466"
                }
            }
        },
        "QLineEdit": {
            "states": [
                "hover",
                "disabled"
            ],
            "default-variant": "default",
            "variants": {
                "default": {
                    "background-color": "--md-sys-color-surface-container-dark",
                    "color": "--md-sys-color-on-surface-dark",
                    "placeholder-color": "--md-ref-palette-neutral-variant30",
                    "selection-background-color": "--md-sys-color-secondary-container-dark",
                    "selection-color": "--md-sys-color-on-secondary-container-dark",
                    "border-color": "--md-sys-color-outline-variant-dark",
                    "border-width": 1,
                    "border-radius": 4,
                    "focus-outline-width": 1,
                    "focus-outline-color": "--md-sys-color-primary-dark",
                    "padding": [
                        8,
                        2
                    ],
                    "hover": {
                        "border-color": "--md-sys-color-outline-dark"
                    },
                    "disabled": {
                        "background-color": "--md-sys-color-surface-container-dark",
                        "opacity": 0.5
                    }
                },
                "search-field": {
                    "background-color": "--md-sys-color-surface-container-low-dark",
                    "selection-background-color": "--md-sys-color-secondary-container-dark",
                    "selection-color": "--md-sys-color-on-secondary-container-dark",
                    "icon": "search",
                    "icon-size": 16,
                    "icon-color": "--md-sys-color-on-surface-dark",
                    "icon-padding": 4
                }
            }
        },
        "QComboBox": {
            "default-variant": "default",
            "variants": {
                "default": {
                    "border-radius": 4,
                    "text-padding": [
                        6,
                        6
                    ],
                    "icon-padding": [
                        6,
                        6
                    ],
                    "focus-outline-width": 2,
                    "background-color": "--md-sys-color-surface-container-highest-dark",
                    "color": "--md-sys-color-on-surface-dark",
                    "menu-background-color": "--md-sys-color-surface-container-low-dark"
                },
                "low": {
                    "background-color": "--md-sys-color-surface-container-low-dark"
                }
            }
        },
        "QScrollBar": {
            "default-variant": "default",
            "variants": {
                "default": {
                    "background-color": "--md-sys-color-surface-container-low-dark",
                    "slider-color": "--md-sys-color-surface-container-highest-dark",
                    "slider-hover-color": "--md-sys-color-primary-dark",
                    "border-width": 10,
                    "border-radius": 8,
                    "width": 16,
                    "min-length": 32
                }
            }
        },
        "QScrollArea": {
            "default-variant": "default",
            "variants": {
                "default": {
                    "background-color": "--md-sys-color-surface-container-low-dark"
                }
            }
        },
        "QFrame": {
            "states": [
                "hover",
                "active",
                "dragging",
                "selected"
            ],
            "default-variant": "default",
            "variants": {
                "default": {
                    "border-radius": 4,
                    "border-width": 0,
                    "border-color": "--md-sys-color-background-dark",
                    "background-color": "--md-sys-color-background-dark"
                },
                "low": {
                    "background-color": "--md-sys-color-surface-container-low-dark"
                },
                "low-square": {
                    "background-color": "--md-sys-color-surface-container-low-dark",
                    "border-radius": 0
                },
                "low-framed": {
                    "background-color": "--md-sys-color-surface-container-low-dark",
                    "border-width": 2,
                    "border-color": "--md-sys-color-outline-variant-dark"
                },
                "low-framed-thin": {
                    "background-color": "--md-sys-color-surface-container-low-dark",
                    "border-width": 1,
                    "border-color": "--md-sys-color-outline-variant-dark"
                },
                "low-table-editor": {
                    "background-color": "--color-table-row",
                    "border-radius": 0,
                    "border-width": 1,
                    "border-color": "--md-sys-color-surface-container-dark",
                    "hover": {
                        "background-color": "--color-table-row-hover"
                    },
                    "selected": {
                        "background-color": "--color-table-row-selected"
                    }
                },
                "high": {
                    "background-color": "--md-sys-color-surface-container-dark"
                },
                "tag": {
                    "border-radius": 10,
                    "border-width": 0
                },
                "item-view": {
                    "background-color": "--md-sys-color-surface-container-dark",
                    "border-color": "--md-sys-color-surface-container-dark",
                    "border-radius": 0,
                    "border-width": 0
                },
                "criterion": {
                    "background-color": "--md-ref-palette-neutral-variant25"
                },
                "entity-card": {
                    "background-color": "--md-sys-color-surface-container-high-dark",
                    "border-radius": 10,
                    "border-width": 2,
                    "border-color": "--md-sys-color-surface-container-high-dark",
                    "default-width": 280,
                    "default-height": 160,
                    "placeholder-icon-color": "--md-ref-palette-neutral35",
                    "border-color-dragging": "--md-custom-color-warning",
                    "border-color-error": "--md-sys-color-error-dark",
                    "loading-overlay-color": "--md-ref-palette-neutral5",
                    "loading-skeleton-color": "--md-ref-palette-neutral30",
                    "hover": {
                        "border-color": "--md-ref-palette-secondary60"
                    },
                    "active": {
                        "border-color": "--md-sys-color-primary-dark"
                    }
                },
                "entity-card-tag": {
                    "background-color": "--ec-chip-background",
                    "background-opacity": 0.71,
                    "border-radius": 4,
                    "padding-h": 5,
                    "padding-v": 3
                },
                "surface": {
                    "background-color": "--md-sys-color-surface-container-highest-dark"
                },
                "contextual-menu": {
                    "background-color": "--md-sys-color-surface-container-lowest-dark",
                    "border-width": 0,
                    "border-radius": 0,
                    "hover": {
                        "background-color": "--md-sys-color-surface-container-dark",
                        "shortcut-background-color": "--md-sys-color-surface-container-high-dark"
                    }
                },
                "debug-r": {
                    "background-color": "#664444"
                },
                "debug-g": {
                    "background-color": "#446644"
                },
                "debug-b": {
                    "background-color": "#444466"
                }
            }
        },
        "QToolTip": {
            "states": [],
            "default-variant": "default",
            "variants": {
                "default": {
                    "padding": [
                        8,
                        8
                    ],
                    "border-radius": 4,
                    "border-width": 1,
                    "border-color": "--md-sys-color-outline-dark",
                    "background-color": "--md-sys-color-background-lowest-dark"
                }
            }
        },
        "QMenu": {
            "states": ["hover", "disabled"],
            "default-variant": "default",
            "variants": {
                "default": {
                    "background-color": "--md-sys-color-surface-container-lowest-dark",
                    "color": "--md-sys-color-on-surface-dark",
                    "shortcut-color": "--md-sys-color-on-surface-dark",
                    "shortcut-background-color": "--md-sys-color-surface-container-dark",
                    "shortcut-opacity": 0.6,
                    "border-radius": 2,
                    "border-width": 1,
                    "border-color": "--md-sys-color-outline-variant-dark",
                    "panel-padding": [0, 0],
                    "item-padding": [10, 10],
                    "item-radius": 0,
                    "item-spacing": 4,
                    "icon-size": 16,
                    "separator-color": "--md-sys-color-outline-variant-dark",
                    "separator-height": 1,
                    "hover": {
                        "background-color": "--md-sys-color-surface-container-dark",
                        "shortcut-background-color": "--md-sys-color-surface-container-high-dark"
                    },
                    "disabled": {
                        "opacity": 0.5
                    }
                },
                "danger": {
                    "background-color": "--md-sys-color-error-container-dark",
                    "color": "--md-sys-color-on-error-container-dark",
                    "hover": {
                        "background-color": "--md-ref-palette-error25"
                    }
                }
            }
        },
        "QLabel": {
            "states": ["disabled", "hover"],
            "default-variant": "default",
            "variants": {
                "default": {
                    "background-color": "transparent",
                    "disabled": {
                        "opacity": 0.5
                    }
                },
                "tag": {
                    "contrast-text": true
                },
                "badge": {
                    "auto-size": true,
                    "auto-size-padding": [1.5, 0.25],
                    "border-radius-fraction": 0.2,
                    "background-color": "@_icon_color",
                    "fill-from-foreground": true,
                    "contrast-text": true
                },
                "pill": {
                    "auto-size": true,
                    "auto-size-padding": [1.5, 0.25],
                    "border-radius-fraction": 0.5,
                    "background-color": "@_icon_color",
                    "fill-from-foreground": true,
                    "contrast-text": true
                },
                "entity-label": {
                    "background-color": "--md-sys-color-surface-container-high-dark",
                    "color": "--md-sys-color-on-surface-dark",
                    "border-radius": 6,
                    "border-width": 0,
                    "icon-text-spacing": 4,
                    "padding": [4, 2],
                    "alignment": "center"
                },
                "entity-label-filled": {
                    "background-color": "@_icon_color",
                    "color": "--md-sys-color-inverse-on-surface-dark",
                    "border-radius": 6,
                    "border-width": 0,
                    "icon-text-spacing": 4,
                    "padding": [4, 2],
                    "alignment": "center"
                },
                "order-option": {
                    "background-color": "transparent",
                    "color": "--md-sys-color-on-surface-dark",
                    "border-radius": 4,
                    "border-width": 0,
                    "icon-text-spacing": 8,
                    "padding": [0, 6],
                    "alignment": "left",
                    "disabled": {
                        "opacity": 0.5
                    },
                    "hover": {
                        "background-color": "--md-sys-color-background-dark"
                    }
                },
                "optional-action": {
                    "background-color": "--md-sys-color-surface-container-lowest-dark",
                    "color": "--md-sys-color-on-surface-dark",
                    "icon-size": 16,
                    "padding": [10, 6],
                    "icon-text-spacing": 8,
                    "hover": {
                        "background-color": "--md-sys-color-surface-container-dark"
                    }
                }
            }
        },
        "QTreeView": {
            "states": [
                "hover",
                "selected",
                "disabled"
            ],
            "default-variant": "default",
            "variants": {
                "default": {
                    "background-color": "--md-sys-color-surface-container-low-dark",
                    "color": "--md-sys-color-on-surface-dark",
                    "border-radius": 4,
                    "border-width": 0,
                    "border-color": "--md-sys-color-background-dark",
                    "indent": 22,
                    "item-height": 28,
                    "item-padding": [
                        4,
                        8
                    ],
                    "icon-text-spacing": 6,
                    "branch-indicator-color": "--md-sys-color-on-surface-dark",
                    "expand-icon-name": "keyboard_arrow_right",
                    "expanded-icon-name": "keyboard_arrow_down",
                    "expand-icon-size": 16,
                    "hover": {
                        "branch-indicator-color": "--md-sys-color-primary-dark",
                        "background-color": "--md-sys-color-surface-container-high-dark"
                    },
                    "selected": {
                        "background-color": "--md-sys-color-primary-container-dark",
                        "color": "--md-sys-color-on-primary-container-dark"
                    },
                    "disabled": {
                        "opacity": 0.5
                    }
                },
                "low": {
                    "background-color": "--md-sys-color-surface-container-low-dark"
                },
                "high": {
                    "background-color": "--md-sys-color-surface-container-dark"
                }
            }
        },
        "QStyledItemDelegate": {
            "states": [
                "hover",
                "checked"
            ],
            "default-variant": "default",
            "variants": {
                "default": {
                    "background-color": "transparent",
                    "color": "--md-sys-color-outline-dark",
                    "checkbox-background-color": "--md-sys-color-surface-container-highest-dark",
                    "checkbox-size": 16,
                    "checkbox-margin": 8,
                    "text-padding": 12,
                    "border-radius": 2,
                    "hover": {
                        "background-color": "--md-sys-color-surface-container-high-dark"
                    },
                    "checked": {
                        "color": "--md-sys-color-on-surface-dark",
                        "checkbox-background-color": "--md-sys-color-primary-dark"
                    }
                }
            }
        },
        "AYTableView": {
            "states": [
                "hover",
                "selected",
                "disabled"
            ],
            "default-variant": "default",
            "variants": {
                "default": {
                    "background-color": "--color-table-row",
                    "background-color-item": "--color-table-row-item",
                    "color": "--color-table-text",
                    "border-radius": 0,
                    "border-width": 1,
                    "border-color": "--md-sys-color-surface-container-dark",
                    "item-height": 32,
                    "item-padding": [
